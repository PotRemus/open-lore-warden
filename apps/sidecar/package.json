{
  "name": "@open-lore-warden/sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx/esm --watch --inspect src/index.ts",
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/bundle.cjs",
    "build:binary": "pnpm run build:bundle && pkg dist/bundle.cjs --targets host --output sidecar",
    "build:rename": "node rename-binary.js",
    "build:sidecar": "pnpm run build:binary && pnpm run build:rename",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@mastra/core": "^1.30.0",
    "@open-lore-warden/domain": "workspace:*",
    "@open-lore-warden/llm-provider": "workspace:*",
    "@open-lore-warden/rules-engine": "workspace:*",
    "@open-lore-warden/shared": "workspace:*",
    "fastify": "^5.8.5",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.3",
    "pino": "^10.3.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
