# ── Sidecar HTTP server ────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
DATA_DIR=./data

# ── LLM server (llama.cpp in prod / LM Studio in dev) ─────────────────────────
# These two variables are shared by the Rust backend (llama.rs) and the
# llm-provider package to target the same inference endpoint.
LLM_HOST=127.0.0.1
LLM_PORT=8080

# ── Stable Diffusion server (stable-diffusion.cpp) ────────────────────────────
# stable_diffusion.rs démarre sd-server sur ce port à la demande (import scénario).
SD_HOST=127.0.0.1
SD_PORT=8081

# ── LLM model aliases (optional) ──────────────────────────────────────────────
# LLM_BASE_URL is constructed from LLM_HOST and LLM_PORT when not set explicitly.
# Override it here if your inference server is on a different machine or path.
# LLM_BASE_URL=http://127.0.0.1:8080/v1

# Model ids forwarded to the inference server.  Leave commented to use the
# server's default / only loaded model.
# LLM_MODEL_INTENT=lmstudio/local-model
# LLM_MODEL_NARRATOR=lmstudio/local-model
# LLM_MODEL_LORE=lmstudio/local-model
# LLM_MODEL_SCENE=lmstudio/local-model
# LLM_MODEL_IMPORT=lmstudio/local-model
